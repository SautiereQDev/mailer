{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "baseUrl": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@src/*": [
        "src/*"
      ]
    },
    "useUnknownInCatchVariables": false,
    "resolveJsonModule": true
  },
  "ts-node": {
    "swc": true,
    "require": [
      "tsconfig-paths/register"
    ]
  },
  "include": [
    "src/**/*.ts",
    "spec/**/*.ts",
    "src/config/index.ts",
    "src/scripts",
    "eslint.config.ts"
  ],
  "exclude": [
    "src/public/*",
    "dist",
    "node_modules"
  ]
}